#!/usr/bin/env bash
# Worker-session guard for protected branch pushes.
set -euo pipefail

hook_name="pre-push"
self_path="$(cd "$(dirname "$0")" && pwd -P)/$(basename "$0")"
managed_dir="${AIGENTRY_GIT_HOOKS_DIR:-$(cd "$(dirname "$0")" && pwd -P)}"

tmp_stdin=$(mktemp "${TMPDIR:-/tmp}/aigentry-pre-push.XXXXXX")
trap 'rm -f "$tmp_stdin"' EXIT
cat > "$tmp_stdin"

canonical_dir() {
  local p="$1"
  [ -d "$p" ] || return 1
  (cd "$p" && pwd -P)
}

same_file() {
  local a="$1" b="$2"
  [ -e "$a" ] && [ -e "$b" ] || return 1
  [ "$(cd "$(dirname "$a")" && pwd -P)/$(basename "$a")" = "$(cd "$(dirname "$b")" && pwd -P)/$(basename "$b")" ]
}

protected_branches() {
  printf '%s\n' "${AIGENTRY_PROTECTED_BRANCHES:-main master}" | tr ',' ' '
}

is_protected_ref() {
  local remote_ref="$1" branch protected
  case "$remote_ref" in
    refs/heads/*) branch="${remote_ref#refs/heads/}" ;;
    *) return 1 ;;
  esac
  for protected in $(protected_branches); do
    protected="${protected#refs/heads/}"
    if [ "$branch" = "$protected" ]; then
      return 0
    fi
  done
  return 1
}

guard_protected_push() {
  local localref localsha remoteref remotesha
  [ "${AIGENTRY_WORKER_SESSION:-}" = "1" ] || return 0
  while read -r localref localsha remoteref remotesha || [ -n "${localref:-}${localsha:-}${remoteref:-}${remotesha:-}" ]; do
    if is_protected_ref "$remoteref"; then
      {
        echo "aigentry: blocked worker-session push to protected branch '$remoteref'."
        echo "aigentry: worker sessions must HOLD; the orchestrator verifies + lands (Rule 32 / dispatch ref No push/merge)."
      } >&2
      return 1
    fi
  done < "$tmp_stdin"
  return 0
}

candidate_from_hooks_path() {
  local managed_canon origin path path_canon candidate
  managed_canon=$(canonical_dir "$managed_dir" 2>/dev/null || true)
  { git config --show-origin --get-all core.hooksPath 2>/dev/null || true; } | while IFS="$(printf '\t')" read -r origin path; do
    [ -n "${path:-}" ] || continue
    path="${path%/}"
    case "$path" in
      /*) ;;
      *) path="$(git rev-parse --show-toplevel 2>/dev/null)/$path" ;;
    esac
    path_canon=$(canonical_dir "$path" 2>/dev/null || true)
    [ -n "$path_canon" ] || continue
    [ -n "$managed_canon" ] && [ "$path_canon" = "$managed_canon" ] && continue
    candidate="$path_canon/$hook_name"
    [ -x "$candidate" ] && printf '%s\n' "$candidate"
  done | tail -n 1
}

candidate_from_git_dir() {
  local common_dir candidate
  common_dir=$(git rev-parse --git-common-dir 2>/dev/null || true)
  [ -n "$common_dir" ] || return 0
  candidate="$common_dir/hooks/$hook_name"
  [ -x "$candidate" ] && printf '%s\n' "$candidate"
  return 0
}

run_chained_hook() {
  local candidate
  candidate=$(candidate_from_hooks_path)
  if [ -z "$candidate" ]; then
    candidate=$(candidate_from_git_dir)
  fi
  [ -n "$candidate" ] || return 0
  same_file "$candidate" "$self_path" && return 0
  "$candidate" "$@" < "$tmp_stdin"
}

guard_protected_push
run_chained_hook "$@"
